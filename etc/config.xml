<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <payment>
            <mockonlinepayment>
                <active>0</active> <!--mandatory-->
                <title>Mock Online Payment</title> <!--mandatory-->
                <model>MockOnlinePaymentFacade</model> <!--critical mandatory-->
                <payment_action>authorize</payment_action> <!--mandatory-->
                <allowspecific>0</allowspecific>
                <can_use_checkout>1</can_use_checkout>
                <can_use_internal>1</can_use_internal>
                <is_gateway>1</is_gateway>
                <can_authorize>1</can_authorize>
                <can_capture>1</can_capture>
                <can_void>1</can_void>
                <cctypes>AE,VI,MC,DI,JCB,DN</cctypes>
                <gateway_url>https://mock-gateway.test/api/pay</gateway_url>
            </mockonlinepayment>
        </payment>
    </default>
</config>
